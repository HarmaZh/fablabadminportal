# ── PostgreSQL (Docker) ────────────────────────────────────────────────────────
# Used by: Express backend (Prisma), ETL pipeline, Streamlit dashboard
POSTGRES_USER=fablab_user
POSTGRES_PASSWORD=fablab_password
POSTGRES_DB=fablab_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Cloud PostgreSQL (Supabase / Neon / Railway) ───────────────────────────────
# Required for Power BI web integration.
# Get this from your Supabase project: Settings → Database → Connection string
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
CLOUD_DATABASE_URL=

# ── Google Sheets (live extraction mode) ──────────────────────────────────────
# Place your service-account JSON key at config/credentials.json
# Share the Google Sheet with your service-account email (viewer access)
GOOGLE_SHEETS_CREDENTIALS_PATH=config/credentials.json
GOOGLE_SHEET_ID=your-google-sheet-id-here
