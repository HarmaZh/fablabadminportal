// Prisma Schema for FabLab Admin Portal
// Database: PostgreSQL

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// =============================================================================
// USER MANAGEMENT
// =============================================================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // Hashed with bcrypt
  firstName String
  lastName  String
  role      String   @default("STAFF") // ADMIN, STAFF, INSTRUCTOR
  active    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventoryLogs InventoryLog[]

  @@map("users")
}

// =============================================================================
// INVENTORY MANAGEMENT
// =============================================================================

model InventoryItem {
  id        String  @id @default(uuid())
  itemId    String  @unique // Custom ID (e.g., "CHOC-001")
  name      String
  type      String  // CHOCOLATE, SOAP, PINS, DRONES, TOOLS, MATERIALS, OTHER
  price     Decimal
  quantity  Int     @default(0)
  minStock  Int     @default(0)
  status    String  // IN_STOCK, LOW_STOCK, OUT_OF_STOCK, DISCONTINUED
  notes     String?
  imageUrl  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?

  logs InventoryLog[]

  @@index([type])
  @@index([status])
  @@map("inventory_items")
}

model InventoryLog {
  id     String        @id @default(uuid())
  itemId String
  item   InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  userId String?
  user   User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  action   String  // CREATED, UPDATED, DELETED, STOCK_ADDED, STOCK_REMOVED
  oldValue String? // Previous state as JSON string
  newValue String? // New state as JSON string
  quantity Int?    // For stock changes
  notes    String?

  createdAt DateTime @default(now())

  @@index([itemId])
  @@index([createdAt])
  @@map("inventory_logs")
}

// =============================================================================
// STAFF MANAGEMENT
// =============================================================================

model Staff {
  id             String  @id @default(uuid())
  staffId        String  @unique // e.g., "STF-001"
  name           String
  email          String  @unique
  role           String  @default("INSTRUCTOR") // INSTRUCTOR, ADMIN, COORDINATOR, VOLUNTEER
  specialization String?
  phone          String?
  active         Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classes Class[]

  @@map("staff")
}

// =============================================================================
// CLASS MANAGEMENT
// =============================================================================

model Class {
  id                  String  @id @default(uuid())
  classId             String  @unique // e.g., "CLS-001"
  name                String
  description         String?
  ageGroup            String? // Youth K-5th, Youth 6th-9th, High School 9th-12th, All Ages
  scheduleDescription String? // e.g., "First Tuesday of the Month"
  isRecurring         Boolean @default(false)
  color               String? // Hex color for calendar view
  status              String  @default("active") // active, inactive, archived
  maxStudents         Int?

  instructorId String?
  instructor   Staff?  @relation(fields: [instructorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments    Enrollment[]
  attendances    Attendance[]
  materialUsages MaterialUsage[]

  @@index([status])
  @@map("classes")
}

// =============================================================================
// STUDENT MANAGEMENT
// =============================================================================

model Student {
  id         String  @id @default(uuid())
  studentId  String  @unique // e.g., "STU-001"
  name       String
  email      String  @unique
  phone      String?
  parentName String? // For youth classes
  ageGroup   String?
  status     String  @default("active") // active, inactive

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments Enrollment[]
  attendances Attendance[]

  @@index([email])
  @@map("students")
}

// =============================================================================
// ENROLLMENTS
// =============================================================================

model Enrollment {
  id               String   @id @default(uuid())
  studentId        String
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId          String
  class            Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  registrationDate DateTime
  status           String   @default("confirmed") // confirmed, incomplete, cancelled
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, classId])
  @@index([classId])
  @@index([status])
  @@map("enrollments")
}

// =============================================================================
// EQUIPMENT
// =============================================================================

model Equipment {
  id              String    @id @default(uuid())
  equipmentId     String    @unique // e.g., "EQ-001"
  name            String
  category        String    // 3D_PRINTER, LASER, DRONE, ROBOTICS, ELECTRONICS, OTHER
  status          String    @default("OPERATIONAL") // OPERATIONAL, MAINTENANCE, OUT_OF_SERVICE
  lastMaintenance DateTime?
  nextMaintenance DateTime?
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([category])
  @@map("equipment")
}

// =============================================================================
// ATTENDANCE
// =============================================================================

model Attendance {
  id        String   @id @default(uuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  date      DateTime
  status    String   @default("present") // present, late, absent
  notes     String?

  createdAt DateTime @default(now())

  @@index([classId])
  @@index([date])
  @@map("attendance")
}

// =============================================================================
// MATERIAL USAGE (populated by ETL pipeline)
// =============================================================================

model MaterialUsage {
  id           String   @id @default(uuid())
  classId      String
  class        Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  instructor   String
  materialName String
  quantityUsed Decimal
  unit         String   // grams, sheets, units, ml
  sessionDate  DateTime
  notes        String?

  createdAt DateTime @default(now())

  @@index([classId])
  @@index([sessionDate])
  @@map("material_usage")
}
